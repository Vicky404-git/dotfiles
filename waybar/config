{
  "layer": "top",
  "position": "top",
  "margin-top": 8,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 10,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "network", "battery"],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

   "clock": {
    "format": "⏳ {:%H:%M}"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "🕯️ {capacity}%",
    "format-icons": ["", "", "", "", ""]
  },

  "network": {
    "format-wifi": "📜 {essid}",
    "format-disconnected": "🐎 No Courier"
  },

  "pulseaudio": {
    "format": "📯 {volume}%",
    "format-muted": "🔇 Silenced"
  }
  }
}
