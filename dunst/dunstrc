[global]
    font = JetBrainsMono Nerd Font 11

    # Proper markup handling (IMPORTANT)
    markup = full
    format = "<b>%s</b>\n%b"

    # Placement and size
    width = 300
    height = 0              # IMPORTANT → dynamic height (don’t fix to 200)
    origin = top-right
    offset = 20x45

    # Aesthetics
    frame_width = 2
    frame_color = "#33ccff"
    corner_radius = 8

    # Spacing
    padding = 15
    horizontal_padding = 15

    # Colors
    background = "#141414"
    foreground = "#ebdbb2"

    # Behavior
    timeout = 5
    ignore_newline = no
    stack_duplicates = true
    show_indicators = yes
    sort = yes

    # History (helps with missed notifications)
    history_length = 20

    # Monitor follow (optional but useful)
    follow = mouse

[urgency_low]
    background = "#141414"
    foreground = "#595959"
    frame_color = "#282828"
    timeout = 3

[urgency_normal]
    background = "#141414"
    foreground = "#ebdbb2"
    frame_color = "#33ccff"
    timeout = 5

[urgency_critical]
    background = "#282828"
    foreground = "#ebdbb2"
    frame_color = "#cc241d"
    timeout = 0
